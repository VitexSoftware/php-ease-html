#!/usr/bin/make -f

%:
	dh $@ --with phpcomposer

override_dh_clean:
	rm -rf debian/test/vendor .phpdoc
	dh_clean

override_dh_prep:
	mkdir -p docs
	rm -f docs/* -r
	phpdoc -d src --title "Vitex Software's Ease Html"
	mkdir -p docs
	mv .phpdoc/build/* docs
	dh_prep


override_dh_auto_test:
	which php && php --version 
	# Note: Tests may require dependencies. If needed, install them via debian/control Build-Depends
	# instead of using composer update. For now, skip tests or ensure dependencies are available.
	# composer update removed - autoloader now generated by phpab in override_dh_install
	# vendor/bin/phpunit --bootstrap tests/Bootstrap.php --configuration phpunit.xml tests/src/
#	dh_auto_test

override_dh_install:
	dh_install
	echo "require_once 'Mail.php';"  >> debian/php-vitexsoftware-ease-html/usr/share/php/EaseHtml/HtmlMailer.php
	echo "require_once 'Mail/mime.php';" >> debian/php-vitexsoftware-ease-html/usr/share/php/EaseHtml/HtmlMailer.php
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//'`'"'  debian/composer.json |sponge debian/php-vitexsoftware-ease-html/usr/share/php/EaseHtml/composer.json
	phpab --output debian/php-vitexsoftware-ease-html/usr/share/php/EaseHtml/autoload.php \
		--basedir debian/php-vitexsoftware-ease-html/usr/share/php/EaseHtml \
		--tolerant \
		debian/php-vitexsoftware-ease-html/usr/share/php/EaseHtml
	install -m0755 -d debian/php-vitexsoftware-ease-html/usr/share/pkg-php-tools/autoloaders
	echo 'vitexsoftware ease-html EaseHtml/autoload.php' > debian/php-vitexsoftware-ease-html/usr/share/pkg-php-tools/autoloaders/php-vitexsoftware-ease-html
